<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Scam Detector Game</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <div class="game-container">

        <!-- Character -->
        <div class="character">
            🕵️ Agent Byte:
            <span id="message">Find the fake website!</span>
        </div>

        <!-- Timer -->
        <div class="timer-bar">
            <div id="timer"></div>
        </div>

        <!-- Question -->
        <h2 id="question">Which website is fake?</h2>

        <!-- Options -->
        <div class="options">
            <div class="card" onclick="selectAnswer(0)" id="option0"></div>
            <div class="card" onclick="selectAnswer(1)" id="option1"></div>
        </div>

        <!-- Score -->
        <div class="score">
            Score: <span id="score">0</span>
        </div>

    </div>

    <script src="script.js"></script>
</body>

</html>